{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "strict": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["bun-types"],
    "paths": {
      "@ckir/corelib": ["./ts-core/src/index.ts"],
      "@ckir/corelib-markets": ["./ts-markets/src/index.ts"],
      "@ckir/corelib-cloud": ["./ts-cloud/src/index.ts"]
    }
  }
}
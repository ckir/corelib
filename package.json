{
    "name": "corelib-monorepo",
    "version": "0.1.14",
    "packageManager": "pnpm@10.33.0",
    "devDependencies": {
        "@biomejs/biome": "^2.4.10",
        "del-cli": "^7.0.0",
        "dependency-cruiser": "^17.3.10",
        "nx": "^22.6.4",
        "tsup": "^8.5.1",
        "typescript": "^6.0.2"
    },
    "scripts": {
        "build-all": "pnpm -r build",
        "watch-all": "pnpm -r watch --parallel",
        "test-all": "pnpm -r test",
        "lint-all": "pnpm -r lint",
        "format-all": "pnpm -r format",
        "docs-all": "pnpm -r docs",
        "clean-all": "pnpm exec npx del-cli --force node_modules dist rust\\target .nx"
    }

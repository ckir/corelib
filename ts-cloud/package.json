{
    "name": "@ckir/corelib-cloud",
    "version": "0.1.14",
    "main": "dist/index.js",
    "type": "module",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "wrangler dev",
        "build": "tsup",
        "postbuild": "node -e \"const fs=require('fs');const path=require('path');const awsDir=path.join('dist','aws');const crDir=path.join('dist','cloudrun');[awsDir, crDir].forEach(d => { if(!fs.existsSync(d)) fs.mkdirSync(d, {recursive:true}); const rust=path.join('..','ts-core','corelib-rust.node'); if(fs.existsSync(rust)) { fs.copyFileSync(rust, path.join(d,'corelib-rust.node')); console.log('✅ Copied corelib-rust.node to ' + d); } });\"",
        "watch": "tsup --watch",
        "test": "vitest",
        "test:worker": "vitest --config vitest.config.ts",
        "lint": "biome check . --write --unsafe --max-diagnostics=100",
        "format": "biome format . --write",
        "docs": "typedoc",
        "clean": "del dist"
    },
    "dependencies": {
        "@ckir/corelib": "workspace:*",
        "@ckir/corelib-markets": "workspace:*",
        "@hono/node-server": "^1.19.13",
        "hono": "^4.12.12",
        "ky": "^2.0.0",
        "serialize-error": "^13.0.1"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.31.1",
        "@cloudflare/vitest-pool-workers": "^0.14.2",
        "@cloudflare/workers-types": "^4.20260408.1",
        "@types/aws-lambda": "^8.10.161",
        "@types/deno": "^2.5.0",
        "@types/node": "^25.5.2",
        "bun-types": "^1.3.11",
        "miniflare": "^4.20260405.0",
        "tsup": "^8.5.1",
        "typedoc": "^0.28.18",
        "typescript": "^6.0.2",
        "vite": "^8.0.7",
        "vitest": "^4.1.3",
        "wrangler": "^4.81.0"
    }
}
